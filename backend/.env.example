# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./backend_battle.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/backend_battle

# ─── Redis / Celery ──────────────────────────────────────────────────────────
# Upstash Redis — get your URL from https://console.upstash.com
# The URL must use rediss:// (double-s) for TLS.
REDIS_URL=rediss://default:<your-upstash-password>@<your-upstash-host>.upstash.io:6379

# Set to true to dispatch benchmark jobs through Celery + Redis.
# Set to false to run them inline via FastAPI BackgroundTasks (no Redis needed).
USE_CELERY=true

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated list of valid X-API-Key values for /submit access.
API_KEYS=dev_key_123,team_pyro_abc

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
